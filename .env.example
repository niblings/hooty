# Hooty 環境変数設定テンプレート

# --- プロバイダ選択 ---
# HOOTY_PROVIDER=bedrock

# --- AWS Bedrock ---
# API キー認証（推奨・最も簡単）
# AWS_BEARER_TOKEN_BEDROCK=your-api-key
# アクセスキー認証
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# リージョン
# AWS_REGION=us-east-1

# --- Azure AI Foundry ---
# AZURE_API_KEY=your-api-key
# AZURE_ENDPOINT=https://your-endpoint.models.ai.azure.com

# --- GitHub ---
# GITHUB_ACCESS_TOKEN=ghp_xxxxxxxxxxxx
